{
  "name": "sharepoint-neon-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Sync service that pulls SharePoint list entries via Microsoft Graph and upserts them into Neon Postgres. Deployed on Vercel and driven by Vercel Cron.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "inspect:columns": "tsx scripts/inspect-columns.ts",
    "migrate": "tsx scripts/migrate.ts",
    "sync:local": "tsx scripts/run-local.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@neondatabase/serverless": "^0.10.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vercel/node": "^5.0.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
