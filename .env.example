# ─── Azure AD app registration (Microsoft Graph, client-credentials flow) ───
# Created under: Azure Portal → App registrations → your app.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Client secret VALUE (not the secret ID). Generated under Certificates & secrets.
AZURE_CLIENT_SECRET=your-client-secret-value

# ─── SharePoint targeting ───
# Site ID, format: "{hostname},{site-guid},{web-guid}".
#   Get it: GET https://graph.microsoft.com/v1.0/sites/{tenant}.sharepoint.com:/sites/{site-name}
SHAREPOINT_SITE_ID=contoso.sharepoint.com,11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222
# List ID (GUID) or list display name.
#   Get it: GET https://graph.microsoft.com/v1.0/sites/{site-id}/lists
SHAREPOINT_LIST_ID=33333333-3333-3333-3333-333333333333

# ─── Neon Postgres ───
# Use the POOLED connection string from the Neon dashboard, with sslmode=require.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ─── Operational ───
# Long random string. Vercel Cron sends this as "Authorization: Bearer <CRON_SECRET>".
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# Optional: SharePoint/Graph page size (default 200, max 5000).
GRAPH_PAGE_SIZE=200
